# PostgreSQL
POSTGRES_DB=audio_scribe
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

# MinIO
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin

# API
API_HOST=0.0.0.0
API_PORT=8000

# Frontend
VITE_API_URL=http://localhost:8000/api

# Whisper (mlx-whisper — Apple Silicon worker, run natively via scripts/run-worker.sh)
WHISPER_MODEL=mlx-community/whisper-large-v3-mlx
WHISPER_LANGUAGE=auto

# Auth / RBAC
# Generate a strong secret, e.g.: python -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET=change-me-to-a-long-random-secret
ACCESS_TOKEN_EXPIRE_MINUTES=120
# Initial administrator, seeded on first startup when the users table is empty.
ADMIN_EMAIL=admin@example.com
ADMIN_USERNAME=admin
ADMIN_PASSWORD=noel1999
